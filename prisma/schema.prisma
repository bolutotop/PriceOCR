generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite" // 开发阶段推荐用 sqlite，上线可换 postgresql
  url      = env("DATABASE_URL")
}

// 1. 香烟基础库 (彻底抛弃地区标签，回归极简)
model Product {
  id           String      @id @default(cuid())
  name         String      @unique
  alias        String?     // 别名，用于 OCR 容错匹配
  
  // 价格历史记录
  priceHistory PriceItem[] 
}

// 2. 报价单/批次 (一次上传对应一个批次)
model PriceSheet {
  id         String      @id @default(cuid())
  title      String?     // 可选标题，例如 "晚班报价"
  
  // --- 核心新增：行情标签 ---
  marketType String      // 行情区分："EXPRESS" (快递行情) 或 "GUANGHUO" (广货行情)
  
  // --- 时间线 ---
  createdAt  DateTime    @default(now()) // 系统记录时间 (你什么时候点的保存)
  recordDate DateTime    @default(now()) // 业务行情时间 (这张表是哪天的价格) -> 用于画折线图
  
  items      PriceItem[]
}

// 3. 具体价格条目
model PriceItem {
  id         String      @id @default(cuid())
  price      Float
  
  // 属于哪张单子
  sheetId    String
  sheet      PriceSheet  @relation(fields: [sheetId], references: [id], onDelete: Cascade)

  // 属于哪个产品 (允许为空，防报错)
  productId  String?    
  product    Product?    @relation(fields: [productId], references: [id])

  // 冗余存一个名字，方便直接查询显示
  rawName    String     
}